# ─────────────────────────────────────────────────────────────────────────────
# ShopSphere — Local Development Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in YOUR values below
# 3. Never commit .env  (it is in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=mySecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLong

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# How to get your App Password (takes ~2 minutes):
#   1. https://myaccount.google.com/security  → enable 2-Step Verification
#   2. https://myaccount.google.com/apppasswords
#   3. App name: ShopSphere  → Create
#   4. Copy the 16-char password (shown once) → paste below WITHOUT spaces
#
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=abcdefghijklmnop

# ── Application URLs ──────────────────────────────────────────────────────────
# Base URL for email links (verification, password reset)
# In production, set this to your frontend URL (e.g., https://shopsphere.in)
APP_BASE_URL=http://localhost:8080
